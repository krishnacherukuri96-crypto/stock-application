generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model IndicatorCache {
  id        String   @id @default(cuid())
  key       String   @unique
  data      Json
  fetchedAt DateTime @default(now())
  expiresAt DateTime

  @@index([key])
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String?
  createdAt DateTime @default(now())
}
